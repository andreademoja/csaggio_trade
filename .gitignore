cat > .gitignore << 'EOF'
# Virtual Environment
venv/
env/
ENV/
.venv/
env.bak/
venv.bak/

# Python bytecode e cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Log e dati temporanei
*.log
logs/
*.csv
*.parquet
*.xlsx
results/
data/raw/
data/processed/

# Jupyter / IPython
.ipynb_checkpoints/
*.ipynb

# OpenClaw / Local specific
.openclaw/
*.json.bak
__pycache__/

# Environment variables e segreti
.env
.env.local
.env.*.local
secrets.json
api_keys.py
credentials.py

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Backtesting results (se non vuoi versionarli)
backtest_results/
results/
reports/
EOF